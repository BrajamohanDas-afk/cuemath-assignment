generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CardType {
  CONCEPT
  DEFINITION
  CLOZE
  EXAMPLE
}

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

model Deck {
  id           String    @id @default(cuid())
  userId       String    @default("local-default-user")
  title        String
  sourceFile   String
  sourceHash   String?
  sourceText   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastReviewAt DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards        Card[]
  sessions     Session[]

  @@index([createdAt])
  @@index([userId, updatedAt])
}

model User {
  id          String   @id
  externalKey String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  decks       Deck[]
  authSessions AuthSession[]
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt, revokedAt])
}

model Card {
  id          String       @id @default(cuid())
  deckId      String
  type        CardType
  front       String
  back        String
  difficulty  Int          @default(2)
  tags        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deck        Deck         @relation(fields: [deckId], references: [id], onDelete: Cascade)
  schedule    CardSchedule?
  reviews     Review[]

  @@index([deckId, type])
}

model CardSchedule {
  id            String    @id @default(cuid())
  cardId         String    @unique
  state          CardState @default(NEW)
  dueAt          DateTime
  intervalDays   Int       @default(0)
  easeFactor     Float     @default(2.5)
  repetition     Int       @default(0)
  lapses         Int       @default(0)
  lastReviewedAt DateTime?
  card           Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([dueAt])
}

model Review {
  id             String       @id @default(cuid())
  cardId          String
  rating          ReviewRating
  responseTimeMs  Int?
  qualityScore    Int?
  answeredAt      DateTime     @default(now())
  nextDueAt       DateTime?
  resultingState  CardState?
  card            Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, answeredAt])
}

model Session {
  id          String   @id @default(cuid())
  deckId       String
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  reviewed     Int      @default(0)
  correct      Int      @default(0)
  avgTimeMs    Int?
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, startedAt])
}
